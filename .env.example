# Copy to .env and fill in. .env is git-ignored.
# docker-compose reads these and passes them to both kabu-trader-jp and kabu-trader-us.
#
# Precedence: config/*.json wins when its matching field is non-empty. So to
# actually use these env vars, clear the corresponding fields in your configs:
#   config/default.json: llm_sentiment.api_key, line.channel_access_token, line.user_id
#   config/us.json:      same three fields

OPENAI_API_KEY=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=

# Gmail SMTP fallback for watchdog alerts (used alongside LINE — LINE has a
# 200 msg/mo free-tier cap; SMTP doesn't, so the watchdog still reaches you
# when the cap is hit).
#   1. Enable 2FA on the sending Gmail account.
#   2. Generate an App Password at https://myaccount.google.com/apppasswords
#   3. Set config/default.json -> email.enabled = true.
#      Leave email.sender/recipient as "" so env vars take effect.
EMAIL_SENDER=
EMAIL_RECIPIENT=
EMAIL_APP_PASSWORD=
