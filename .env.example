# Copy to .env and fill in. .env is git-ignored.
# docker-compose reads these and passes them to both kabu-trader-jp and kabu-trader-us.
#
# Precedence: config/*.json wins when its matching field is non-empty. So to
# actually use these env vars, clear the corresponding fields in your configs:
#   config/default.json: llm_sentiment.api_key, line.channel_access_token, line.user_id
#   config/us.json:      same three fields

OPENAI_API_KEY=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=
